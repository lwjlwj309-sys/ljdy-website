---
interface Props {
  icon: string;
  title: string;
  description: string;
  href?: string;
  tag?: string;
}

const { icon, title, description, href, tag } = Astro.props;
---

{
  href ? (
    <a href={href} class="group block h-full">
      <div class="bg-white rounded-xl p-6 shadow-sm hover:shadow-lg transition-all border border-gray-100 h-full relative overflow-hidden">
        {tag && (
          <div class="absolute top-4 right-4">
            <span class="inline-block px-3 py-1 text-xs font-medium bg-gold-100 text-gold-700 rounded-full">
              {tag}
            </span>
          </div>
        )}
        <div class="w-14 h-14 bg-gold-100 rounded-xl flex items-center justify-center mb-5">
          <span class="text-3xl">{icon}</span>
        </div>
        <h3 class="text-xl font-semibold text-dark-800 mb-3 group-hover:text-gold-600 transition-colors">
          {title}
        </h3>
        <p class="text-gray-600 text-sm leading-relaxed">{description}</p>
      </div>
    </a>
  ) : (
    <div class="bg-white rounded-xl p-6 shadow-sm hover:shadow-lg transition-all border border-gray-100 h-full relative overflow-hidden">
      {tag && (
        <div class="absolute top-4 right-4">
          <span class="inline-block px-3 py-1 text-xs font-medium bg-gold-100 text-gold-700 rounded-full">
            {tag}
          </span>
        </div>
      )}
      <div class="w-14 h-14 bg-gold-100 rounded-xl flex items-center justify-center mb-5">
        <span class="text-3xl">{icon}</span>
      </div>
      <h3 class="text-xl font-semibold text-dark-800 mb-3">{title}</h3>
      <p class="text-gray-600 text-sm leading-relaxed">{description}</p>
    </div>
  )
}
