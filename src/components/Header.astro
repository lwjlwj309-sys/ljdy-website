---
const navItems = [
  { name: "首页", href: "/" },
  { name: "关于我们", href: "/about" },
  { name: "追款收款", href: "/yutiao" },
  { name: "债务优化", href: "/yutiao" },
  { name: "保房服务", href: "/baofang" },
  { name: "法律咨询", href: "/consult" },
];

const currentPath = Astro.url.pathname;
---

<header class="bg-dark-900 shadow-lg sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16">
      <!-- Logo -->
      <div class="flex items-center">
        <a href="/" class="flex items-center">
          <img src="/images/logo.png" alt="律金盾" class="h-10 w-auto" />
        </a>
      </div>

      <!-- Desktop Navigation -->
      <nav class="hidden md:flex space-x-8">
        {navItems.map((item) => (
          <a
            href={item.href}
            class={`text-sm font-medium transition-colors ${
              currentPath === item.href
                ? "text-gold-400"
                : "text-gray-300 hover:text-gold-400"
            }`}
          >
            {item.name}
          </a>
        ))}
      </nav>

      <!-- CTA Button -->
      <div class="hidden md:block">
        <a
          href="/contact"
          class="bg-gold-500 text-dark-900 px-4 py-2 rounded-lg text-sm font-bold hover:bg-gold-400 transition-colors"
        >
          立即咨询
        </a>
      </div>

      <!-- Mobile menu button -->
      <div class="md:hidden">
        <button
          id="mobile-menu-btn"
          class="text-gray-300 hover:text-gold-400 p-2"
          aria-label="菜单"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-dark-800 border-t border-dark-700">
    <div class="px-4 py-3 space-y-2">
      {navItems.map((item) => (
        <a
          href={item.href}
          class={`block px-3 py-2 rounded-lg text-base font-medium ${
            currentPath === item.href
              ? "bg-dark-700 text-gold-400"
              : "text-gray-300 hover:bg-dark-700"
          }`}
        >
          {item.name}
        </a>
      ))}
      <a
        href="/contact"
        class="block px-3 py-2 bg-gold-500 text-dark-900 rounded-lg text-base font-bold text-center mt-4"
      >
        立即咨询
      </a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  btn?.addEventListener("click", () => {
    menu?.classList.toggle("hidden");
  });
</script>
