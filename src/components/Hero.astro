---
interface Props {
  title: string;
  subtitle?: string;
  ctaText?: string;
  ctaHref?: string;
}

const { 
  title = "化债有路，重生有道", 
  subtitle = "律金盾——保险+调解+法律一站式债事服务平台\n统一品牌 · 统一标准 · 统一服务", 
  ctaText = "立即咨询",
  ctaHref = "/contact"
} = Astro.props;
---

<section class="bg-gradient-to-br from-blue-600 to-blue-800 text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28">
    <div class="text-center max-w-3xl mx-auto">
      <h1 class="text-4xl md:text-5xl font-bold mb-6 leading-tight">
        {title}
      </h1>
      <p class="text-xl md:text-2xl text-blue-100 mb-8 leading-relaxed whitespace-pre-line">
        {subtitle}
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={ctaHref}
          class="bg-white text-blue-600 px-8 py-4 rounded-lg font-semibold hover:bg-blue-50 transition-colors"
        >
          {ctaText}
        </a>
        <a
          href="/yutiao"
          class="border-2 border-white text-white px-8 py-4 rounded-lg font-semibold hover:bg-white/10 transition-colors"
        >
          了解债务修复
        </a>
      </div>
      <!-- 数据背书 -->
      <div class="mt-12 flex justify-center gap-8 text-blue-100 text-sm">
        <span>📊 3.5万亿市场规模</span>
        <span>💰 900元超低门槛</span>
        <span>✅ 调解失败全额退费</span>
      </div>
    </div>
  </div>
</section>
