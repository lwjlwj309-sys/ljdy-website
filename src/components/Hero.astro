---
interface Props {
  title?: string;
  subtitle?: string;
  ctaText?: string;
  ctaHref?: string;
  secondCtaText?: string;
  secondCtaHref?: string;
}

const { 
  title = "帮您追回欠款 · 守住资产 · 优化债务", 
  subtitle = "债务人资产保全与债务优化专业服务平台", 
  ctaText = "立即咨询",
  ctaHref = "/contact",
  secondCtaText = "了解服务详情",
  secondCtaHref = "#services"
} = Astro.props;
---

<section class="bg-gradient-to-br from-dark-900 via-dark-800 to-dark-700 text-white relative overflow-hidden">
  <!-- 金色装饰线 -->
  <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-gold-400 via-gold-500 to-gold-400"></div>
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-32 relative">
    <div class="text-center max-w-4xl mx-auto">
      <div class="inline-block px-4 py-1.5 rounded-full bg-gold-500/20 border border-gold-500/30 text-gold-400 text-sm font-medium mb-6">
        合法合规 · 专业守护 · 助力上岸
      </div>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight">
        {title}
      </h1>
      <p class="text-xl md:text-2xl text-gray-300 mb-8 leading-relaxed">
        {subtitle}
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={ctaHref}
          class="bg-gold-500 text-dark-900 px-8 py-4 rounded-lg font-bold hover:bg-gold-400 transition-colors text-lg"
        >
          {ctaText}
        </a>
        <a
          href={secondCtaHref}
          class="border-2 border-gold-500 text-gold-400 px-8 py-4 rounded-lg font-semibold hover:bg-gold-500/10 transition-colors text-lg"
        >
          {secondCtaText}
        </a>
      </div>
      <!-- 核心价值观 -->
      <div class="mt-12 flex flex-wrap justify-center gap-6 text-sm">
        <span class="flex items-center gap-2 text-gold-400">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
          帮您追回欠款
        </span>
        <span class="flex items-center gap-2 text-gold-400">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
          守住资产
        </span>
        <span class="flex items-center gap-2 text-gold-400">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
          优化债务
        </span>
        <span class="flex items-center gap-2 text-gold-400">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
          帮您上岸
        </span>
      </div>
    </div>
  </div>
</section>
