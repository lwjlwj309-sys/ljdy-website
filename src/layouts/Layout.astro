---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "律金盾 - 债务人资产保全与债务优化专业服务平台，帮您追回欠款、守住资产、优化债务、帮您上岸" } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} - 律金盾</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Noto+Sans+SC:wght@400;500;600;700;900&display=swap" rel="stylesheet" />
  </head>
  <body class="font-sans text-dark-700 bg-white">
    <slot />
  </body>
</html>

<style is:global>
  * {
    font-family: 'Noto Sans SC', 'Inter', sans-serif;
  }
  html {
    scroll-behavior: smooth;
  }
</style>
