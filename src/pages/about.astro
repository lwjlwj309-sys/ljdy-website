---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="关于我们" description="了解律金盾 - 债务人资产保全与债务优化专业服务平台">
  <Header />

  <main>
    <!-- Page Header -->
    <section class="bg-gradient-to-br from-dark-900 via-dark-800 to-dark-700 text-white py-16 relative">
      <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-gold-400 via-gold-500 to-gold-400"></div>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h1 class="text-4xl font-bold mb-4">关于我们</h1>
        <p class="text-xl text-gray-300">债务人资产保全与债务优化专业服务平台</p>
      </div>
    </section>

    <!-- 使命与定位 -->
    <section class="py-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl mx-auto">
          <h2 class="text-2xl font-bold text-dark-800 mb-6">平台定位</h2>
          <p class="text-gray-600 leading-relaxed mb-8">
            律金盾——债务人资产保全与债务优化专业服务平台。我们不是站在债权人那边，也不是盲目站在债务人那边。我们站在规则这边，帮助债务人在合法合规的前提下，做到他们能做到的一切。
          </p>

          <h2 class="text-2xl font-bold text-dark-800 mb-6">创始人故事</h2>
          <div class="bg-dark-800 rounded-xl p-8 text-white mb-12">
            <p class="text-gray-300 leading-relaxed mb-4">
              创始人在保险行业深耕30年，从一线业务员到省公司副总经理，深度掌握保险资产保全机制；后又从事3年银行不良资产处置，完整了解金融机构追债逻辑和法院执行规则。
            </p>
            <p class="text-gray-300 leading-relaxed mb-4">
              他看到了太多本可以避免的憾事——很多家庭不是没有资产，而是不知道规则，不知道时间窗口，不知道在哪个节点该做什么。
            </p>
            <p class="text-gold-400 font-bold text-lg">
              这就是律金盾存在的意义：知道规则的全貌，在合法合规的前提下，真正守护家庭的核心资产。
            </p>
          </div>

          <h2 class="text-2xl font-bold text-dark-800 mb-6">核心理念</h2>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
            <div class="text-center p-6 bg-gray-50 rounded-xl border border-gray-100">
              <div class="text-3xl font-bold text-gold-600 mb-2">合法合规</div>
              <p class="text-gray-600 text-sm">始终在法律框架内操作</p>
            </div>
            <div class="text-center p-6 bg-gray-50 rounded-xl border border-gray-100">
              <div class="text-3xl font-bold text-gold-600 mb-2">专业守护</div>
              <p class="text-gray-600 text-sm">30年行业经验全链路视角</p>
            </div>
            <div class="text-center p-6 bg-gray-50 rounded-xl border border-gray-100">
              <div class="text-3xl font-bold text-gold-600 mb-2">助力上岸</div>
              <p class="text-gray-600 text-sm">帮您追款、保资、优债、护权</p>
            </div>
          </div>

          <h2 class="text-2xl font-bold text-dark-800 mb-6">合作伙伴</h2>
          <div class="space-y-4">
            <div class="bg-white border border-gray-200 rounded-xl p-6">
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 bg-gold-100 rounded-lg flex items-center justify-center shrink-0">
                  <span class="text-2xl">🏛️</span>
                </div>
                <div>
                  <h3 class="font-semibold text-dark-800 mb-1">海峡金桥财产保险股份有限公司</h3>
                  <p class="text-gray-600 text-sm">直属福建省国资委隶属的国有法人全国性保险公司，提供《司法调解费用补偿保险》，国资占比80%，为服务提供资金安全保障。</p>
                </div>
              </div>
            </div>
            <div class="bg-white border border-gray-200 rounded-xl p-6">
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 bg-gold-100 rounded-lg flex items-center justify-center shrink-0">
                  <span class="text-2xl">⚖️</span>
                </div>
                <div>
                  <h3 class="font-semibold text-dark-800 mb-1">苏商法律服务中心</h3>
                  <p class="text-gray-600 text-sm">在司法部门指导下成立，具备正规司法备案资质，由专业调解员执行调解，协商结果具备法律效力。</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
