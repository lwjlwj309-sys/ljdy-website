---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="关于我们" description="了解律金盾 - 债事综合服务平台的倡导者与践行者">
  <Header />

  <main>
    <!-- Page Header -->
    <section class="bg-gradient-to-br from-blue-600 to-blue-800 text-white py-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h1 class="text-4xl font-bold mb-4">关于我们</h1>
        <p class="text-xl text-blue-100">债事综合服务平台的倡导者与践行者</p>
      </div>
    </section>

    <!-- Company Introduction -->
    <section class="py-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl mx-auto">
          <h2 class="text-2xl font-bold text-gray-900 mb-6">公司定位</h2>
          <p class="text-gray-600 leading-relaxed mb-8">
            律金盾致力于构建一个保险保障、金融机构、调解机构"三位一体"的债事综合服务平台。我们秉持"专业、中立、高效"的原则，为您提供合规、有温度的法律与债事化解方案，从源头化解金融矛盾，重塑社会信用。
          </p>

          <h2 class="text-2xl font-bold text-gray-900 mb-6">核心理念</h2>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
            <div class="text-center p-6 bg-gray-50 rounded-xl">
              <div class="text-3xl font-bold text-blue-600 mb-2">专业</div>
              <p class="text-gray-600 text-sm">资深调解员与法律团队</p>
            </div>
            <div class="text-center p-6 bg-gray-50 rounded-xl">
              <div class="text-3xl font-bold text-blue-600 mb-2">中立</div>
              <p class="text-gray-600 text-sm">公平公正的调解服务</p>
            </div>
            <div class="text-center p-6 bg-gray-50 rounded-xl">
              <div class="text-3xl font-bold text-blue-600 mb-2">高效</div>
              <p class="text-gray-600 text-sm">快速响应与解决方案</p>
            </div>
          </div>

          <h2 class="text-2xl font-bold text-gray-900 mb-6">合作伙伴</h2>
          <div class="space-y-4">
            <div class="bg-white border border-gray-200 rounded-xl p-6">
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center shrink-0">
                  <span class="text-2xl">🏛️</span>
                </div>
                <div>
                  <h3 class="font-semibold text-gray-900 mb-1">海峡金桥财产保险股份有限公司</h3>
                  <p class="text-gray-600 text-sm">直属福建省国资委隶属的国有法人全国性保险公司，提供《司法调解费用补偿保险》，国资占比80%，为服务提供资金安全保障。</p>
                </div>
              </div>
            </div>
            <div class="bg-white border border-gray-200 rounded-xl p-6">
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center shrink-0">
                  <span class="text-2xl">⚖️</span>
                </div>
                <div>
                  <h3 class="font-semibold text-gray-900 mb-1">苏商法律服务中心</h3>
                  <p class="text-gray-600 text-sm">在司法部门指导下成立，具备正规司法备案资质，由专业调解员执行调解，协商结果具备法律效力。</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
